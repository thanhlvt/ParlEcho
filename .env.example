# =========================================================
# App — chỉ public key, an toàn để commit file .env.example
# Lấy từ: Supabase Dashboard → Project Settings → API
# =========================================================
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...your-publishable-key-here

# =========================================================
# Sentry (error tracking) — DSN không phải bí mật, an toàn để bundle vào app
# Lấy từ: Sentry → Project Settings → Client Keys (DSN)
# =========================================================
# EXPO_PUBLIC_SENTRY_DSN=https://...@o....ingest.de.sentry.io/...

# =========================================================
# Edge Functions secrets — KHÔNG để trong app, set bằng:
#   npx supabase secrets set GOOGLE_GENAI_API_KEY=...
# Lấy từ: Google AI Studio → aistudio.google.com → Get API key
# Không cần Google Cloud Console, không cần bật API riêng
# =========================================================
# GOOGLE_GENAI_API_KEY=AIza...
