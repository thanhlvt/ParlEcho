{
  "expo": {
    "name": "ParlEcho",
    "slug": "parlechho",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#5B4CF5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.parlechho.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "ParlEcho cần microphone để ghi âm giọng nói luyện phát âm."
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#5B4CF5"
      },
      "package": "com.parlechho.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "ParlEcho cần microphone để ghi âm giọng nói luyện phát âm."
        }
      ],
      "expo-font",
      "expo-dev-client",
      [
        "@siteed/audio-studio",
        {
          "microphonePermission": "ParlEcho cần microphone để hội thoại trực tiếp với AI."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "parlechho",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3cfa7a05-c79c-4336-9c14-1f9399fc7499"
      }
    },
    "owner": "thanhlvt"
  }
}
