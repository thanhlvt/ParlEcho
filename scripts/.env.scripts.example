# Copy this file to .env.scripts (same folder) and fill in values.
# .env.scripts is git-ignored — never commit secrets.

# Supabase project URL — same as EXPO_PUBLIC_SUPABASE_URL in your app .env
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# service_role key (Settings → API → service_role) — DO NOT use anon key here
SUPABASE_SERVICE_ROLE_KEY=eyJh...

# Google Generative AI key (same as used in Edge Functions)
GOOGLE_GENAI_API_KEY=AIza...
