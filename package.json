{
  "name": "parlechho",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "generate-audio": "node scripts/generate-audio.mjs",
    "generate-scenarios-sql": "node scripts/generate-scenarios-sql.mjs",
    "lint": "expo lint",
    "test": "jest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "eas-build-pre-install": "if command -v sdkmanager >/dev/null 2>&1; then yes | sdkmanager --install \"cmake;3.31.6\"; fi"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sentry/cli": "^3.5.1",
    "@sentry/react-native": "~7.2.0",
    "@siteed/expo-audio-studio": "^3.2.1",
    "@supabase/supabase-js": "^2.45.4",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.12",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-speech": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "promise": "^8.3.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-audio-api": "^0.12.2",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "prettier": "3.8.4",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@siteed/audio-studio"
        ]
      }
    },
    "install": {
      "exclude": [
        "react-native-worklets"
      ]
    }
  }
}
